import numpy as np
from scipy.io import wavfile

# إعدادات هندسة الصوت السيبراني
sample_rate = 44100
duration = 0.6  # طول الصوت

t = np.linspace(0, duration, int(sample_rate * duration), endpoint=False)

# دمج موجات جيبية مشوشة لتوليد Glitch رقمي خشن
wave = np.sin(2 * np.pi * 150 * t) * 0.4
wave += np.sin(2 * np.pi * 80 * (t ** 2)) * 0.3  # تردد متغير سريع ليعطي انطباع النبضة الإلكترونية
wave += np.random.normal(0, 0.15, size=t.shape)  # ضوضاء بيضاء محاكية للتشويش

# إضافة قطع حاد للموجات لمحاكاة تعطل الإشارة (Digital Clipping)
wave = np.clip(wave, -0.5, 0.5)

# تحويل الصوت ليكون متوافقاً مع صيغة 16-bit WAV
audio_data = (wave * 32767).astype(np.int16)

# حفظ الملف النهائي
wavfile.write('glitch.wav', sample_rate, audio_data)
print("✅ تم توليد ملف الصوت السايبراني بنجاح باسم: glitch.wav")
